# Backend Environment Configuration
# Copy this file to .env and update values as needed

# Application Environment
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info

# Request Handling Timeouts (seconds)
REQUEST_TIMEOUT=30          # Hard timeout for all requests
UPLOAD_TIMEOUT=60           # Soft timeout for /upload endpoint
DATA_TIMEOUT=120            # Timeout for /data computations
MAX_UPLOAD_SIZE=52428800    # 50 MB in bytes

# File Storage
CACHE_DIR=/tmp/mps_uploads  # Railway ephemeral storage
CLEANUP_INTERVAL=3600       # Cleanup old uploads every hour
KEEP_LATEST=5               # Keep only 5 latest uploads

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Optional: Redis for distributed caching
# REDIS_URL=redis://localhost:6379

# Optional: Database for persistent storage
# DATABASE_URL=postgresql://user:password@localhost/dbname

# Optional: S3 for file storage
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# S3_BUCKET=your-bucket
